# Based on the official Arch Linux kernel PKGBUILD
# https://gitlab.archlinux.org/archlinux/packaging/packages/linux/

pkgbase=linux-vivepro2
pkgver=7.0.3.arch1
pkgrel=1
pkgdesc='Linux with Vive Pro 2 patches'
url='https://github.com/santeri3700/vive-pro-2-on-linux'
arch=(x86_64)
license=(GPL2)
makedepends=(
  bc
  cpio
  gettext
  libelf
  pahole
  perl
  python
  tar
  xz
)
options=('!strip')
_srcname=linux-${pkgver%.*}
_srctag=v${pkgver%.*}-${pkgver##*.}
source=(
  https://cdn.kernel.org/pub/linux/kernel/v${pkgver%%.*}.x/${_srcname}.tar.{xz,sign}
  https://github.com/archlinux/linux/releases/download/$_srctag/linux-$_srctag.patch.zst{,.sig}
  config # the main kernel config file
  "0001-drm-edid-rename-VESA-block-parsing-functions-to-more-generic-name_v7.patch"  # [PATCH v7 1/7] drm/edid: rename VESA block parsing functions to more generic name: https://lore.kernel.org/all/20251202110218.9212-2-iam@lach.pw/
  "0002-drm-edid-prepare-for-VESA-vendor-specific-data-block-extension_v7.patch"     # [PATCH v7 2/7] drm/edid: prepare for VESA vendor-specific data block extension: https://lore.kernel.org/all/20251202110218.9212-3-iam@lach.pw/
  "0003-drm-edid-MSO-should-only-be-used-for-non-eDP-displays_v7.patch"              # [PATCH v7 3/7] drm/edid: MSO should only be used for non-eDP displays: https://lore.kernel.org/all/20251202110218.9212-4-iam@lach.pw/
  "0004-drm-edid-parse-DSC-DPP-passthru-support-flag-for-mode-VII-timings_v7.patch"  # [PATCH v7 4/7] drm/edid: parse DSC DPP passthru support flag for mode VII timings: https://lore.kernel.org/all/20251202110218.9212-5-iam@lach.pw/
  "0005-drm-edid-for-consistency-use-mask-everywhere-for-block-rev-parsing_v7.patch" # [PATCH v7 5/7] drm/edid: for consistency, use mask everywhere for block rev parsing: https://lore.kernel.org/all/20251202110218.9212-6-iam@lach.pw/
  "0006-drm-edid-parse-DRM-VESA-dsc-bpp-target_v7.patch"                             # [PATCH v7 6/7] drm/edid: parse DRM VESA dsc bpp target: https://lore.kernel.org/all/20251202110218.9212-7-iam@lach.pw/
  "0007-drm-amd-use-fixed-dsc-bits-per-pixel-from-edid_v7.patch"                     # [PATCH v7 7/7] drm/amd: use fixed dsc bits-per-pixel from edid: https://lore.kernel.org/all/20251202110218.9212-8-iam@lach.pw/
)
